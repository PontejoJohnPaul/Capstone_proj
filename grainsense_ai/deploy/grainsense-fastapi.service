[Unit]
Description=GrainSense AI - FastAPI server
After=network.target mysql.service

[Service]
Type=simple
# Adjust this path to wherever you deploy the project on the VPS
WorkingDirectory=/opt/grainsense_ai
ExecStart=/opt/grainsense_ai/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5
User=www-data
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
